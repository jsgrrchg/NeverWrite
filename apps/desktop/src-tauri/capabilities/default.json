{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Default capabilities for VaultAI",
    "windows": ["main", "note-*", "settings", "vault-*"],
    "permissions": [
        "core:default",
        "dialog:allow-open",
        "core:window:allow-start-dragging",
        "core:window:allow-close",
        "core:webview:allow-create-webview-window",
        "opener:default"
    ]
}
