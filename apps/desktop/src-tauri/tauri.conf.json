{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "VaultAI",
    "version": "0.1.0",
    "identifier": "com.vaultai",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["vaultai"]
            }
        },
        "updater": {
            "endpoints": [],
            "pubkey": ""
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app", "dmg", "nsis"],
        "createUpdaterArtifacts": true,
        "resources": {
            "binaries/": "binaries/",
            "embedded/": "embedded/",
            "../dist/": "frontend-dist/"
        },
        "macOS": {
            "minimumSystemVersion": "12.0",
            "entitlements": "Entitlements.plist"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "app": {
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost asset: vaultai-file: http://vaultai-file.localhost https://vaultai-file.localhost https://www.youtube.com; worker-src 'self' blob:; img-src 'self' asset: data: vaultai-file: http://vaultai-file.localhost https://vaultai-file.localhost https: http:; style-src 'self' 'unsafe-inline'; frame-src https://www.youtube.com https://www.youtube-nocookie.com",
            "assetProtocol": {
                "enable": false,
                "scope": []
            }
        },
        "windows": []
    }
}
