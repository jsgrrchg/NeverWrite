{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName": "VaultAI",
    "version": "0.1.0",
    "identifier": "com.vaultai",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "app": {
        "security": {
            "csp": "default-src 'self'; img-src 'self' asset: https: http: data:; style-src 'self' 'unsafe-inline'; frame-src https://www.youtube.com https://www.youtube-nocookie.com",
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        },
        "windows": [
            {
                "title": "VaultAI",
                "width": 1200,
                "height": 800,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "trafficLightPosition": {
                    "x": 14,
                    "y": 18
                }
            }
        ]
    }
}
