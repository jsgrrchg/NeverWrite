{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "VaultAI",
    "version": "0.1.0",
    "identifier": "com.vaultai",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build"
    },
    "bundle": {
        "active": true,
        "targets": ["app", "nsis", "msi"],
        "resources": ["binaries/*", "embedded/**/*"],
        "macOS": {
            "minimumSystemVersion": "12.0",
            "entitlements": "Entitlements.plist"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "app": {
        "security": {
            "csp": "default-src 'self'; connect-src 'self' asset: https://www.youtube.com; worker-src 'self' blob:; img-src 'self' asset: https: http: data:; style-src 'self' 'unsafe-inline'; frame-src https://www.youtube.com https://www.youtube-nocookie.com",
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        },
        "windows": []
    }
}
